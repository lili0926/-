# ═══════════════════════════════════════════════════════
# Memory Constellations — 环境变量模板
# 复制为 .env 后填入实际值
# ═══════════════════════════════════════════════════════

# ── 必填 ──
# 数据库加密密钥（64位hex，用 `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` 生成）
SANCTUARY_ENCRYPTION_KEY=

# Session 密钥（64位随机hex）
SESSION_SECRET=

# 登录密码（明文，启动时会自动 bcrypt 哈希）
LOGIN_PASSWORD=

# LLM API Key
API_KEY=

# ── LLM 渠道（可选，但至少配一个）──
# Gemini API Key（直连 Google）
GEMINI_API_KEY=

# OpenRouter API Key（走 OpenRouter 代理，支持更多模型）
# OPENROUTER_API_KEY=

# DeepSeek API Key（国内用户推荐）
# DEEPSEEK_API_KEY=

# ── 向量模型（可选）──
# Jina Embedding API Key（默认使用本地 fastembed，不填则自动下载模型）
# JINA_API_KEY=

# ── 外部服务（可选）──
# Google Calendar 服务账号 JSON 路径
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-calendar-sa.json
# GOOGLE_CALENDAR_ID=your-email@gmail.com

# 和风天气 API Key（https://dev.qweather.com）
# QWEATHER_API_KEY=

# FITBIT API（健康数据）
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=

# ── PWA 推送（可选）──
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ── 其他可选 ──
# 出站代理（国内访问 Google API 用）
# HTTP_PROXY=http://127.0.0.1:7890

# StackChan 机器人 Token
# STACKCHAN_TOKEN=

# OwnTracks 位置推送 Token
# LOCATION_PUSH_TOKEN=

# TMDB API Key（影院电影元数据，可选）
# TMDB_API_KEY=

# 知乎开放平台 Access Key（可选）
# ZHIHU_ACCESS_KEY=

# 端口（默认 3000）
# PORT=3000
