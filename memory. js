const MEMORY_KEY="aiMemory";


//读取记忆
function getMemory(){

    const data=localStorage.getItem(MEMORY_KEY);

    if(!data){
        return {
            user:[],
            facts:[],
            chats:[]
        };
    }


    try{
        return JSON.parse(data);

    }catch(e){

        console.error("memory读取失败",e);

        return {
            user:[],
            facts:[],
            chats:[]
        };
    }

}



//保存记忆
function saveMemory(memory){

    localStorage.setItem(
        MEMORY_KEY,
        JSON.stringify(memory)
    );

}



//添加记忆
function addMemory(text,type="facts"){


    let memory=getMemory();


    if(!memory[type]){
        memory[type]=[];
    }


    memory[type].push({

        text:text,

        time:new Date().toLocaleString()

    });


    saveMemory(memory);


}



