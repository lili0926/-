// 自动判断一句话是否值得记忆
function checkMemory(text){


    const keywords=[

        "喜欢",
        "讨厌",
        "不要忘记",
        "记住",
        "我是",
        "我的",
        "以后",
        "习惯",
        "偏好"

    ];



    return keywords.some(
        k=>text.includes(k)
    );


}



